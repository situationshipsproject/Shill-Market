generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth
  walletAddress String? @unique
  email         String? @unique
  phone         String? @unique
  privyUserId   String? @unique

  // Profile
  username    String? @unique
  displayName String?
  bio         String?
  avatarUrl   String?
  bannerUrl   String?

  // Trust
  tier            UserTier @default(ANON)
  isVerified      Boolean  @default(false)
  kycCompleted    Boolean  @default(false)
  isAdmin         Boolean  @default(false)
  isSuperAdmin    Boolean  @default(false)
  socialsVerified Boolean  @default(false)
  isBanned        Boolean  @default(false)

  // Social links
  twitterUrl  String?
  githubUrl   String?
  tiktokUrl   String?
  websiteUrl  String?
  telegramUrl String?

  // Relations
  listings              Listing[]
  ordersAsBuyer         Order[]        @relation("BuyerOrders")
  ordersAsSeller        Order[]        @relation("SellerOrders")
  reviewsGiven          Review[]       @relation("ReviewsGiven")
  reviewsReceived       Review[]       @relation("ReviewsReceived")
  conversationsAsP1     Conversation[] @relation("ConvP1")
  conversationsAsP2     Conversation[] @relation("ConvP2")
  messagesSent          Message[]

  @@map("users")
}

enum UserTier {
  ANON
  VERIFIED
  ELITE
  INSTITUTION
}

// ─── LISTINGS ────────────────────────────────────────────────────────────────

model Listing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String
  category    Category
  tags          String[]
  tokenContract String?

  status     ListingStatus @default(ACTIVE)
  isFeatured Boolean       @default(false)

  // Relations
  sellerId String
  seller   User      @relation(fields: [sellerId], references: [id])
  packages Package[]
  orders   Order[]

  @@map("listings")
}

enum Category {
  DEVELOPMENT
  DESIGN_ART
  MARKETING
  COMMUNITY
  CALLERS_KOLS
  STRATEGY
  RESEARCH_ALPHA
  BROKERAGE
  COMPLIANCE
  BESC_ECOSYSTEM
}

enum ListingStatus {
  ACTIVE
  PAUSED
  DRAFT
  REMOVED
}

// ─── PACKAGES ────────────────────────────────────────────────────────────────

model Package {
  id           String   @id @default(cuid())
  name         String
  description  String
  price        Float
  currency     String   @default("USDC")
  deliveryDays Int
  revisions    Int      @default(1)
  features     String[]

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  orders    Order[]

  @@map("packages")
}

// ─── ORDERS ──────────────────────────────────────────────────────────────────

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status        OrderStatus   @default(PENDING)
  amount        Float
  currency      String        @default("USDC")
  paymentMethod PaymentMethod
  txHash        String?

  escrowStatus EscrowStatus @default(HOLDING)
  deliveredAt  DateTime?
  completedAt  DateTime?
  disputedAt   DateTime?

  // Relations
  buyerId   String
  buyer     User    @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId  String
  seller    User    @relation("SellerOrders", fields: [sellerId], references: [id])
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  packageId String
  package   Package @relation(fields: [packageId], references: [id])
  review    Review?

  @@map("orders")
}

enum OrderStatus {
  PENDING
  ACTIVE
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
  REFUNDED
}

enum EscrowStatus {
  HOLDING
  RELEASED
  REFUNDED
  DISPUTED
}

enum PaymentMethod {
  CRYPTO_WALLET
  CREDIT_CARD
  INTERNAL_BALANCE
}

// ─── REVIEWS ─────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  rating  Int
  comment String?

  orderId    String @unique
  order      Order  @relation(fields: [orderId], references: [id])
  reviewerId String
  reviewer   User   @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User   @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@map("reviews")
}

// ─── MESSAGING ───────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participant1Id String
  participant2Id String
  participant1   User      @relation("ConvP1", fields: [participant1Id], references: [id])
  participant2   User      @relation("ConvP2", fields: [participant2Id], references: [id])
  messages       Message[]
  orderId        String?

  @@map("conversations")
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  content        String
  isRead         Boolean @default(false)
  flagged        Boolean @default(false)

  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@map("messages")
}
